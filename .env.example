# Required AWX secrets. Keep the real values only in .env (which is git-ignored).
AWX_ADMIN_PASSWORD=ChangeMe-Internal-Only-123!
AWX_SECRET_KEY=replace-with-a-real-secret-key-at-least-50-characters-long

# ── Credential-safe deployment diagnostics ──────────────────────
# Enables phase labels, client/context details, an authentication probe, and
# kubectl request logging. Verbosity is capped at 6 to avoid request bodies.
DEBUG_LOGGING=false
KUBECTL_VERBOSITY=6

# ── k3d bootstrap images ─────────────────────────────────────────
# Full image references. Empty values retain the k3d/k3s defaults documented
# in README.md. Docker pulls these before Kubernetes exists.
K3D_NODE_IMAGE=
K3D_PROXY_IMAGE=

# ── AWX Operator images ──────────────────────────────────────────
AWX_OPERATOR_IMAGE=
KUBE_RBAC_PROXY_IMAGE=

# ── AWX workload images ──────────────────────────────────────────
# Repository/tag variables are paired and must be set together. The EE and
# projects-init variables are complete image references including a tag.
AWX_IMAGE_REPOSITORY=
AWX_IMAGE_TAG=
AWX_CONTROL_PLANE_EE_IMAGE=
AWX_DEFAULT_EE_IMAGE=
AWX_REDIS_IMAGE_REPOSITORY=
AWX_REDIS_IMAGE_TAG=
AWX_POSTGRES_IMAGE_REPOSITORY=
AWX_POSTGRES_IMAGE_TAG=
AWX_PROJECTS_INIT_IMAGE=

# Prefix only K3s-owned system images (CoreDNS, pause, local-path provisioner,
# metrics-server, and embedded manifests). Do not include https:// or a tag.
K3S_SYSTEM_DEFAULT_REGISTRY=

# ── Corporate HTTP proxy ─────────────────────────────────────────
# NO_PROXY is required when either proxy is configured. The deployment adds
# Kubernetes service/pod CIDRs, cluster DNS suffixes, localhost, RFC1918
# networks, and k3d host/node names to this list automatically.
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=localhost,127.0.0.1,.svc,.svc.cluster.local

# ── Authenticated/private registry ───────────────────────────────
# REGISTRY_SERVER is a hostname with an optional port (no URL scheme).
# Username/password are optional, but must be supplied together. CA files must
# exist and be non-empty. Set TLS verification false only for a test registry.
REGISTRY_SERVER=
REGISTRY_USERNAME=
REGISTRY_PASSWORD=
REGISTRY_CA_FILE=
REGISTRY_PULL_SECRET_NAME=corporate-registry-pull
REGISTRY_TLS_VERIFY=true

# ── Corporate CA inside AWX ──────────────────────────────────────
# Path to a non-empty PEM bundle to trust in AWX and execution environments.
# This can point to the same file as REGISTRY_CA_FILE. Empty disables it.
AWX_CA_BUNDLE_FILE=
